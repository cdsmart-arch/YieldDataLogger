<Window x:Class="YieldDataLogger.Manager.SubscriptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select subscribed instruments"
        Width="720" Height="600" MinWidth="540" MinHeight="400"
        Background="#0E1117" Foreground="#E6E6E6"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Icon="appicon.ico"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3FB950"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C333B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#E6E6E6"/>
        </Style>

        <!-- CheckBoxColumn in a DataGrid normally needs two clicks (first selects the cell for
             "edit mode"). A template column with a plain CheckBox toggles on the first click. -->
        <Style x:Key="SubGridCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0E1117"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="RowBackground" Value="#0E1117"/>
            <Setter Property="AlternatingRowBackground" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="Foreground" Value="#E6E6E6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="20,16" BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Subscribed instruments" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock x:Name="HeaderSub"
                           Text="Choose the symbols this Agent should stream. Changes apply live - no restart needed."
                           Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- History / backfill settings -->
        <Border Grid.Row="1" Background="#0D1117" Padding="20,10" BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- History days -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,32,0">
                    <TextBlock Text="Days of history:"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="HistoryDaysBox"
                             Width="64" Padding="6,4" VerticalAlignment="Center"
                             ToolTip="How many days of price history the Agent backfills from Azure on first run (or after Clear History). Default: 30."
                             TextChanged="OnHistoryDaysChanged"/>
                    <TextBlock Text="days"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Backfill delay -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Backfill delay:"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="BackfillDelayBox"
                             Width="64" Padding="6,4" VerticalAlignment="Center"
                             ToolTip="Milliseconds to pause between downloading each symbol during backfill. Lower = faster but more CPU/disk load (0 = flat out). Default: 300."
                             TextChanged="OnHistoryDaysChanged"/>
                    <TextBlock Text="ms between symbols"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- Toolbar: search + select all / none -->
        <Grid Grid.Row="2" Margin="20,12,20,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchBox"
                     ToolTip="Filter by symbol or category"
                     TextChanged="OnSearchChanged"/>
            <Button Grid.Column="1" Content="Select all"   Margin="8,0,0,0" Click="OnSelectAll"/>
            <Button Grid.Column="2" Content="Select none"  Margin="8,0,0,0" Click="OnSelectNone"/>
        </Grid>

        <!-- Grid of instruments -->
        <DataGrid Grid.Row="3" x:Name="Grid" Margin="20,6,20,12"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="44">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{StaticResource SubGridCheckBox}"
                                      IsChecked="{Binding Subscribed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn     Header="SYMBOL"   Binding="{Binding CanonicalSymbol}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn     Header="CATEGORY" Binding="{Binding Category}"        Width="160" IsReadOnly="True"/>
                <DataGridTextColumn     Header="SOURCE"   Binding="{Binding Source}"          Width="140" IsReadOnly="True"/>
                <DataGridTextColumn     Header="INVESTING PID" Binding="{Binding InvestingPid}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn     Header="CNBC"     Binding="{Binding CnbcSymbol}"      Width="*"   IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer: counters + Apply / Cancel -->
        <Border Grid.Row="4" Background="{StaticResource PanelBrush}" Padding="20,12" BorderBrush="#21262D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText"
                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="CancelBtn" Content="Close" Margin="8,0" Click="OnCancel"/>
                <Button Grid.Column="2" x:Name="ApplyBtn"  Content="Apply" Style="{StaticResource PrimaryButton}" Click="OnApply" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
