<Window x:Class="YieldDataLogger.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YieldDataLogger  -  Agent Monitor"
        Width="880" Height="560" MinWidth="640" MinHeight="360"
        Background="#0E1117" Foreground="#E6E6E6"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Icon="appicon.ico"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="ConnectedBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="ReconnectingBrush" Color="#D29922"/>
        <SolidColorBrush x:Key="DisconnectedBrush" Color="#F85149"/>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0E1117"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="RowBackground" Value="#0E1117"/>
            <Setter Property="AlternatingRowBackground" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Menlo"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="Foreground" Value="#E6E6E6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: state + stats -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="20,16" BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StateDot" Width="14" Height="14" Fill="{StaticResource DisconnectedBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StateText"
                                   Text="STARTING..."
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="#E6E6E6"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="HubText"
                               Text="(waiting for status file)"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               Margin="24,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button x:Name="SymbolsButton" Content="Symbols..."
                            Click="OnSymbolsClick"
                            HorizontalAlignment="Right" Margin="0,0,0,6"
                            Background="#21262D" Foreground="#E6E6E6"
                            BorderBrush="#30363D" BorderThickness="1"
                            Padding="12,4" FontSize="12" FontWeight="SemiBold"
                            ToolTip="Choose which instruments this Agent subscribes to"/>
                    <TextBlock x:Name="UptimeText" Text="Uptime: -" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TicksText" Text="Ticks: -" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    <TextBlock x:Name="LastTickText" Text="Last tick: -" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main table -->
        <DataGrid Grid.Row="1" x:Name="SymbolsGrid" Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SYMBOL"   Binding="{Binding Symbol}"        Width="120"/>
                <DataGridTextColumn Header="PRICE"    Binding="{Binding PriceDisplay}"  Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <!-- Foreground per row tracks tick direction: green up, red down, neutral
                             until the first real change. -->
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding PriceBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.CellStyle>
                        <!-- Background is a row-owned brush whose Color is animated on each tick,
                             producing a brief green/red flash behind the price. Inherits padding /
                             border / selection behaviour from the implicit DataGridCell style. -->
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Background" Value="{Binding PriceFlashBrush}"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="AGE"      Binding="{Binding AgeDisplay}"    Width="120"/>
                <DataGridTextColumn Header="ROWS"     Binding="{Binding RowsDisplay}"   Width="100"/>
                <DataGridTextColumn Header="LAST UPDATE (UTC)" Binding="{Binding LastUpdateDisplay}" Width="180"/>
                <DataGridTextColumn Header="NOTE"     Binding="{Binding Error}"         Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="20,10" BorderBrush="#21262D" BorderThickness="0,1,0,0">
            <StackPanel>
                <TextBlock x:Name="FooterText1" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBlock x:Name="FooterText2" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
