{
  // This file is safe to commit - it contains NO secrets.
  // Secrets (Storage connection strings, etc.) are injected as Container Apps environment
  // variables at runtime. ASP.NET Core maps "Storage__Tables__ConnectionString" env vars
  // to the JSON path Storage:Tables:ConnectionString automatically.
  //
  // Required env vars to set in Container Apps (or locally with dotnet user-secrets):
  //   Storage__Tables__ConnectionString  = your Azure Storage connection string
  //   (optional) Storage__Sql__ConnectionString = Azure SQL connection string if using SQL
  //
  // See infra/azure-bootstrap.ps1 for the az CLI commands to create resources and set
  // these secrets, or set them manually in the Azure Portal under
  //   Container Apps → your-app → Settings → Environment variables → Secrets
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "YieldDataLogger": "Information"
    }
  },
  "Storage": {
    "Backend": "table",
    "Tables": {
      "Enabled": true,
      // Connection string injected from env var: Storage__Tables__ConnectionString
      "ConnectionString": "",
      "PriceTicksTableName": "PriceTicks"
    },
    "Sql": {
      "Enabled": false
    }
  },
  "Collector": {
    "Sinks": {
      "Sqlite": { "Enabled": false },
      "Scid":   { "Enabled": false }
    },
    "Cnbc": {
      "Enabled": true,
      "PollIntervalMs": 2000
    },
    "Investing": {
      "Enabled": true,
      "Transport": "playwright",
      "Headful": false
    }
  }
}
